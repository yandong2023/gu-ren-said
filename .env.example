# Optional DeepSeek enhancement.
# The app always searches local/authentic quote candidates first.
# DeepSeek can plan search hints first, then rerank verified candidates.
# It must not create quotes or sources.
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com/chat/completions
# DEEPSEEK_ENABLED=1
# DEEPSEEK_PLANNER_ENABLED=1

# Optional: if you later add sqlite-vec locally.
# SQLITE_VEC_PATH=/absolute/path/to/sqlite_vec

# The app works without DeepSeek and without sqlite-vec.
