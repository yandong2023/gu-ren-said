# Optional DeepSeek enhancement.
# The app always searches local/authentic quote candidates first.
# DeepSeek can plan search hints first, then rerank verified candidates.
# It must not create quotes or sources.
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com/chat/completions
# DEEPSEEK_ENABLED=1
# DEEPSEEK_PLANNER_ENABLED=1
# Persistent cache uses the Upstash Redis variables below when configured.
# DEEPSEEK_PLAN_CACHE_TTL_SECONDS=2592000
# DEEPSEEK_RERANK_CACHE_TTL_SECONDS=604800

# Optional search trends, feedback, and SEO query pages.
# If configured, searches are counted in Redis and /hot becomes dynamic.
# Feedback buttons are also stored in Redis at grs:feedback.
# Without these variables, the app uses built-in fallback hot queries and feedback is acknowledged but not persisted.
# UPSTASH_REDIS_REST_URL=https://...
# UPSTASH_REDIS_REST_TOKEN=...
# QUERY_INDEX_MIN_COUNT=5

# Optional: if you later add sqlite-vec locally.
# SQLITE_VEC_PATH=/absolute/path/to/sqlite_vec

# The app works without DeepSeek, Redis, and sqlite-vec.
